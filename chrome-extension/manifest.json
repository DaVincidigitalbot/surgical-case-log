{
  "manifest_version": 3,
  "name": "Cyrionyx – Clinical Case Log → ACGME Export",
  "version": "1.0.0",
  "description": "Export your surgical cases from ClinicalCaseLog directly into the ACGME Case Log System (ADS). Built by CYRIONYX for surgical training workflows.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://clinicalcaselog.com/*",
    "https://apps.acgme.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://apps.acgme.org/*"],
      "js": ["acgme-filter.js", "content-acgme.js"],
      "css": ["content-acgme.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
